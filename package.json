{
  "name": "ado-claude-code",
  "version": "0.1.0",
  "description": "Claude Code MCP server plugin for Azure DevOps integration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ado-claude-code": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "claude-code",
    "mcp",
    "azure-devops",
    "work-items",
    "tsg"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "pnpm": "^10.30.3",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "azure-devops-node-api": "^15.1.2",
    "pino": "^10.3.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  }
}
