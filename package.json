{
  "name": "ado-claude-code",
  "version": "1.2.0",
  "description": "Claude Code plugin for Azure DevOps integration",
  "main": "dist/cli.js",
  "bin": {
    "ado-claude-code": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist",
    "version:bump": "node scripts/bump-version.js"
  },
  "keywords": [
    "claude-code",
    "plugin",
    "azure-devops",
    "work-items",
    "tsg"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "pnpm": "^10.30.3",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "azure-devops-node-api": "^15.1.2",
    "pino": "^10.3.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  }
}
